{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "portrait.png", "use": "@vercel/static" },
    { "src": "KALOS.png", "use": "@vercel/static" },
    { "src": "AGATHOS LOGO .png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
